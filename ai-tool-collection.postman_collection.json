{
  "info": {
    "name": "AI Tool Collection - Backend Verification",
    "description": "Full verification for currently implemented backend features: auth, multimodal chat, session history, PDF upload, PDF RAG chat, and signed S3 file access.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "chatId", "value": "chat-demo-001" },
    { "key": "imageChatId", "value": "chat-image-001" },
    { "key": "pdfChatId", "value": "pdf-demo-001" },
    { "key": "travelChatId", "value": "travel-demo-001" },
    { "key": "pdfFileId", "value": "" },
    { "key": "pdfFileUrl", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"xiaoming\",\n  \"password\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          },
          "description": "Create a test user. If the username already exists, backend should return a business error."
        },
        {
          "name": "Login (auto-saves token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('login response success', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "if (json && json.data) {",
                  "  pm.collectionVariables.set('token', json.data);",
                  "  console.log('Token saved to collection variable: token');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"xiaoming\",\n  \"password\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Chat",
      "item": [
        {
          "name": "Text chat",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/ai/chat?prompt=Hello, who are you?&chatId={{chatId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "chat"],
              "query": [
                { "key": "prompt", "value": "Hello, who are you?" },
                { "key": "chatId", "value": "{{chatId}}" }
              ]
            }
          },
          "description": "Streaming text chat for module 2."
        },
        {
          "name": "Chat without token (expect 401)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/ai/chat?prompt=hello&chatId={{chatId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "chat"],
              "query": [
                { "key": "prompt", "value": "hello" },
                { "key": "chatId", "value": "{{chatId}}" }
              ]
            }
          }
        },
        {
          "name": "Chat with image (multimodal)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "prompt", "value": "What do you see in this image?", "type": "text" },
                { "key": "chatId", "value": "{{imageChatId}}", "type": "text" },
                { "key": "files", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/ai/chat",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "chat"]
            }
          },
          "description": "Pick one or more image files in the files field. This verifies image upload, stored_file metadata, attachment binding, and multimodal chat."
        }
      ]
    },
    {
      "name": "3. PDF",
      "item": [
        {
          "name": "Upload PDF (auto-saves pdfFileId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('pdf upload response success', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "if (json && json.data && json.data.fileId) {",
                  "  pm.collectionVariables.set('pdfFileId', String(json.data.fileId));",
                  "  console.log('Saved pdfFileId =', json.data.fileId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/ai/pdf/upload/{{pdfChatId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "pdf", "upload", "{{pdfChatId}}"]
            }
          },
          "description": "Pick a PDF file. This verifies PDF session creation, S3 upload, stored_file metadata save, and vector ingestion."
        },
        {
          "name": "Get signed PDF URL (auto-saves pdfFileUrl)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('signed pdf url response success', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "if (json && json.data) {",
                  "  pm.collectionVariables.set('pdfFileUrl', json.data);",
                  "  console.log('Saved pdfFileUrl =', json.data);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/ai/pdf/file/{{pdfFileId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "pdf", "file", "{{pdfFileId}}"]
            }
          },
          "description": "Use after upload. This verifies signed S3 URL generation for the uploaded PDF."
        },
        {
          "name": "PDF chat",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "prompt", "value": "Summarize the main content of this PDF.", "type": "text" },
                { "key": "chatId", "value": "{{pdfChatId}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/ai/pdf/chat",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "pdf", "chat"]
            }
          },
          "description": "RAG chat over the uploaded PDF. Run this after PDF upload."
        },
        {
          "name": "PDF chat without token (expect 401)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "prompt", "value": "Summarize the PDF.", "type": "text" },
                { "key": "chatId", "value": "{{pdfChatId}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/ai/pdf/chat",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "pdf", "chat"]
            }
          }
        },
        {
          "name": "Get signed PDF URL without token (expect 401)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/ai/pdf/file/{{pdfFileId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "pdf", "file", "{{pdfFileId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "4. History",
      "item": [
        {
          "name": "List chat sessions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/ai/history/chat",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "history", "chat"]
            }
          }
        },
        {
          "name": "Chat session messages",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/ai/history/chat/{{chatId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "history", "chat", "{{chatId}}"]
            }
          },
          "description": "Returns chat_message records for one normal chat session, including signed image URLs when present."
        },
        {
          "name": "Delete chat session",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/ai/history/chat/{{chatId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "history", "chat", "{{chatId}}"]
            }
          },
          "description": "Deletes one normal chat session and cascades chat_session, chat_message, attachments, stored_file metadata, S3 objects, and chat memory."
        },
        {
          "name": "Image chat session messages",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/ai/history/chat/{{imageChatId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "history", "chat", "{{imageChatId}}"]
            }
          },
          "description": "Use this after multimodal chat to verify image attachments are returned with signed URLs."
        },
        {
          "name": "Delete image chat session",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/ai/history/chat/{{imageChatId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "history", "chat", "{{imageChatId}}"]
            }
          },
          "description": "Deletes one multimodal chat session and cascades related MySQL data, S3 image objects, and chat memory."
        },
        {
          "name": "List pdf sessions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/ai/history/pdf",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "history", "pdf"]
            }
          }
        },
        {
          "name": "PDF session messages",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/ai/history/pdf/{{pdfChatId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "history", "pdf", "{{pdfChatId}}"]
            }
          },
          "description": "Use this after PDF chat to verify user/assistant PDF messages were persisted."
        },
        {
          "name": "Delete PDF session",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/ai/history/pdf/{{pdfChatId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "history", "pdf", "{{pdfChatId}}"]
            }
          },
          "description": "Deletes one PDF session and cascades chat_session, chat_message, attachments, stored_file metadata, S3 PDF objects, chat memory, and Redis vector chunks."
        },
        {
          "name": "Delete travel session",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/ai/history/travel/{{travelChatId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "history", "travel", "{{travelChatId}}"]
            }
          },
          "description": "Reserved for module 4. Deletes one travel session after the travel chat flow is implemented."
        }
      ]
    }
  ]
}
